#!/bin/bash
set -e

# The PKG filename carries the install credentials: fendit_setup_<domain>_<sessionid>.pkg
# We find it in the user's Downloads folder and pass domain + session to the Go binary.
# The Go binary handles all further setup — this script does nothing security-sensitive.

PKG=$(find /Users/*/Downloads -maxdepth 1 -name 'fendit_setup_*.pkg' 2>/dev/null | sort | tail -1)

if [ -z "$PKG" ]; then
    echo "postinstall: fendit_setup_*.pkg not found in any Downloads folder" >&2
    exit 1
fi

# Filename format: fendit_setup_<domain>_<sessionid>.pkg
# LastIndex split: domain may contain underscores, session_id never does.
BASENAME=$(basename "$PKG" .pkg)            # fendit_setup_acmecorp_abc123
REST="${BASENAME#fendit_setup_}"            # acmecorp_abc123
SESSION="${REST##*_}"                       # abc123
DOMAIN="${REST%_${SESSION}}"               # acmecorp

if [ -z "$DOMAIN" ] || [ -z "$SESSION" ] || [ "$DOMAIN" = "$REST" ]; then
    echo "postinstall: cannot parse domain/token from filename: $BASENAME" >&2
    exit 1
fi

exec /usr/local/bin/fendit-agent --install-domain "$DOMAIN" --install-token "$SESSION"
